{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "vibecut app",
  "version": "0.1.0",
  "identifier": "ai.jocodingax.aside",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run package:runtime && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "vibecut app",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/runtime/add_subtitles": "runtime/add_subtitles",
      "resources/runtime/analyze_auto_edit": "runtime/analyze_auto_edit",
      "resources/runtime/export_bridge": "runtime/export_bridge",
      "resources/runtime/capcut_editor": "runtime/capcut_editor"
    }
  }
}
