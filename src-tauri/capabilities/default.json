{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "aside default capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "fs:default",
    "fs:read-files",
    {
      "identifier": "fs:scope",
      "allow": ["**"]
    },
    "shell:default"
  ]
}
